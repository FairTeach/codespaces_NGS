{
  "name": "Codespace • Desktop (noVNC)",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "vscode",
      "webPort": "6080",
      "vncPort": "5901",
      "installOhMyZsh": false
    }

  },
  "forwardPorts": [6080, 5901],
  "portsAttributes": {
    "6080": { "label": "Desktop (noVNC)", "onAutoForward": "openBrowser", "requireLocalPort": true },
    "5901": { "label": "VNC", "onAutoForward": "silent", "requireLocalPort": true }
  },

  "postCreateCommand": "bash .devcontainer/postCreate.sh"

}
