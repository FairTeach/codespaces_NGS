{
    "name": "Codespace Desktop (noVNC)",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
    "features": {
        // https://containers.dev/features#:~:text=apt%20packages%20%20Rocker%20Project,org%2Fdevcontainer
        // https://github.com/rocker-org/devcontainer-features/tree/main/src/rstudio-server 
      "ghcr.io/rocker-org/devcontainer-features/miniforge:2": {
      },
      "ghcr.io/devcontainers/features/desktop-lite:1": {
        "installFirefox": false,
        "password": "vscode",
        "webPort": "6080",
        "vncPort": "5901",
        "installOhMyZsh": false
      },
      "ghcr.io/devcontainers/features/docker-in-docker:2": {}

    },
    "forwardPorts": [
        6080,
        5901,
        5173
      ],
      "portsAttributes": {
        "6080": {
          "label": "Desktop (noVNC)",
          "onAutoForward": "openBrowser",
          "requireLocalPort": true
        },
        "5901": {
          "label": "VNC",
          "onAutoForward": "silent",
          "requireLocalPort": true
        },
         "5173": {
         "label": "brick web UI",
         "onAutoForward": "openBrowser",
         "requireLocalPort": true
        }
      },
      "postCreateCommand": "bash .devcontainer/postCreate.sh",
      "customizations": {
        "vscode": {
          "extensions": [
            "tomoki1207.pdf",
            "yzane.markdown-pdf",
            "ms-vscode.live-server",
            "streetsidesoftware.code-spell-checker",
            "streetsidesoftware.code-spell-checker-english",
            "bioSyntax.bioSyntax",
            "igvteam.vscode-igv",
            "mathematic.vscode-pdf@0.1.6"
          ]
        }
      }
 }
    
